{% comment %}
  Usage: {% render 'logo-svg', width: 60, height: 60 %}
{% endcomment %}
{%- assign svg_width  = width  | default: 60 -%}
{%- assign svg_height = height | default: 60 -%}

<svg xmlns="http://www.w3.org/2000/svg"
     viewBox="0 0 120 120"
     width="{{ svg_width }}"
     height="{{ svg_height }}"
     role="img"
     aria-label="{{ shop.name }}">
  <defs>
    <!-- Central warm glow -->
    <radialGradient id="logo-glow-{{ svg_width }}" cx="50%" cy="50%" r="50%">
      <stop offset="0%"   stop-color="#F5E07A" stop-opacity="0.40"/>
      <stop offset="50%"  stop-color="#C4A84C" stop-opacity="0.14"/>
      <stop offset="100%" stop-color="#C4A84C" stop-opacity="0"/>
    </radialGradient>
    <!-- Ring glow filter -->
    <filter id="ring-glow-{{ svg_width }}" x="-30%" y="-30%" width="160%" height="160%">
      <feGaussianBlur stdDeviation="1.5" result="blur"/>
      <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
    </filter>
  </defs>

  <!-- Ambient glow behind everything -->
  <circle cx="60" cy="60" r="58" fill="url(#logo-glow-{{ svg_width }})"/>

  <!-- Laurel leaves — 18 leaves, one every 20°, full circle wreath -->
  <!-- Each leaf is an almond shape placed at the 3-o'clock position,
       then rotated around the centre (60,60) to spread around the ring.
       Leaf base sits at r=34 (just outside the ring), tip at r=47. -->
  <g fill="#C4A84C">
    <g transform="rotate(0 60 60)">   <path d="M94,60 C96,55 105,55 107,60 C105,65 96,65 94,60Z" opacity="0.90"/></g>
    <g transform="rotate(20 60 60)">  <path d="M94,60 C96,55 105,55 107,60 C105,65 96,65 94,60Z" opacity="0.88"/></g>
    <g transform="rotate(40 60 60)">  <path d="M94,60 C96,55 105,55 107,60 C105,65 96,65 94,60Z" opacity="0.88"/></g>
    <g transform="rotate(60 60 60)">  <path d="M94,60 C96,55 105,55 107,60 C105,65 96,65 94,60Z" opacity="0.88"/></g>
    <g transform="rotate(80 60 60)">  <path d="M94,60 C96,55 105,55 107,60 C105,65 96,65 94,60Z" opacity="0.88"/></g>
    <g transform="rotate(100 60 60)"> <path d="M94,60 C96,55 105,55 107,60 C105,65 96,65 94,60Z" opacity="0.88"/></g>
    <g transform="rotate(120 60 60)"> <path d="M94,60 C96,55 105,55 107,60 C105,65 96,65 94,60Z" opacity="0.88"/></g>
    <g transform="rotate(140 60 60)"> <path d="M94,60 C96,55 105,55 107,60 C105,65 96,65 94,60Z" opacity="0.88"/></g>
    <g transform="rotate(160 60 60)"> <path d="M94,60 C96,55 105,55 107,60 C105,65 96,65 94,60Z" opacity="0.88"/></g>
    <g transform="rotate(180 60 60)"> <path d="M94,60 C96,55 105,55 107,60 C105,65 96,65 94,60Z" opacity="0.90"/></g>
    <g transform="rotate(200 60 60)"> <path d="M94,60 C96,55 105,55 107,60 C105,65 96,65 94,60Z" opacity="0.88"/></g>
    <g transform="rotate(220 60 60)"> <path d="M94,60 C96,55 105,55 107,60 C105,65 96,65 94,60Z" opacity="0.88"/></g>
    <g transform="rotate(240 60 60)"> <path d="M94,60 C96,55 105,55 107,60 C105,65 96,65 94,60Z" opacity="0.88"/></g>
    <g transform="rotate(260 60 60)"> <path d="M94,60 C96,55 105,55 107,60 C105,65 96,65 94,60Z" opacity="0.88"/></g>
    <g transform="rotate(280 60 60)"> <path d="M94,60 C96,55 105,55 107,60 C105,65 96,65 94,60Z" opacity="0.88"/></g>
    <g transform="rotate(300 60 60)"> <path d="M94,60 C96,55 105,55 107,60 C105,65 96,65 94,60Z" opacity="0.88"/></g>
    <g transform="rotate(320 60 60)"> <path d="M94,60 C96,55 105,55 107,60 C105,65 96,65 94,60Z" opacity="0.88"/></g>
    <g transform="rotate(340 60 60)"> <path d="M94,60 C96,55 105,55 107,60 C105,65 96,65 94,60Z" opacity="0.88"/></g>
  </g>

  <!-- Glowing ring — rendered on top of leaf bases -->
  <circle cx="60" cy="60" r="33"
          stroke="#F5E07A" stroke-width="2.5" fill="none"
          filter="url(#ring-glow-{{ svg_width }})" opacity="0.95"/>
  <!-- Thinner inner ring for depth -->
  <circle cx="60" cy="60" r="33"
          stroke="#C4A84C" stroke-width="1" fill="none" opacity="0.6"/>

  <!-- VB Monogram -->
  <text x="60" y="70"
        font-family="'Playfair Display', Georgia, serif"
        font-size="30"
        fill="#C4A84C"
        text-anchor="middle"
        font-weight="500"
        letter-spacing="-1"
        opacity="0.88">VB</text>

</svg>
