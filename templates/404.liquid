<div class="container" style="padding-top: 9rem; padding-bottom: 6rem; text-align: center; min-height: 60vh; display: flex; flex-direction: column; align-items: center; justify-content: center;">
  <p class="eyebrow">404</p>
  <h1 style="margin-bottom: 1rem;">Page Not Found</h1>
  <div class="divider divider--center"></div>
  <p style="color: var(--color-muted); max-width: 420px; margin: 1.5rem auto 2.5rem;">
    The page you're looking for has moved or doesn't exist. Let's get you back on track.
  </p>
  <div style="display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center;">
    <a href="{{ routes.root_url }}" class="btn btn--primary">Back to Home</a>
    <a href="{{ routes.collections_url }}" class="btn btn--outline">Shop All Products</a>
  </div>
</div>
