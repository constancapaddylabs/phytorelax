<footer class="site-footer" role="contentinfo">
  <div class="container">
    <div class="footer-grid">

      <!-- Brand -->
      <div class="footer-brand">
        <a href="{{ routes.root_url }}" class="site-logo footer-logo" aria-label="{{ shop.name }}">
          {%- if section.settings.logo != blank -%}
            <img src="{{ section.settings.logo | image_url: width: 160 }}"
                 alt="{{ shop.name }}"
                 class="site-logo__img"
                 loading="lazy">
          {%- else -%}
            {{ section.settings.logo_text | default: shop.name }}
          {%- endif -%}
        </a>
        <p>{{ section.settings.tagline }}</p>
        <div class="footer-social">
          {%- if section.settings.instagram_url != blank -%}
            <a href="{{ section.settings.instagram_url }}" class="social-btn" aria-label="Instagram" target="_blank" rel="noopener">IG</a>
          {%- endif -%}
          {%- if section.settings.facebook_url != blank -%}
            <a href="{{ section.settings.facebook_url }}" class="social-btn" aria-label="Facebook" target="_blank" rel="noopener">FB</a>
          {%- endif -%}
          {%- if section.settings.tiktok_url != blank -%}
            <a href="{{ section.settings.tiktok_url }}" class="social-btn" aria-label="TikTok" target="_blank" rel="noopener">TK</a>
          {%- endif -%}
        </div>
      </div>

      <!-- Shop -->
      <div class="footer-col">
        <h4>{{ section.settings.col1_heading | default: 'Shop' }}</h4>
        <ul>
          <li><a href="/#bestsellers">Bestsellers</a></li>
          <li><a href="/#our-story">Our Story</a></li>
          <li><a href="/#shop-range">Shop by Range</a></li>
          <li><a href="/#ingredients">Our Formula</a></li>
          <li><a href="/#reviews">Reviews</a></li>
        </ul>
      </div>

      <!-- Contact -->
      <div class="footer-col">
        <h4>{{ section.settings.col2_heading | default: 'Contact' }}</h4>
        <ul>
          {%- if section.settings.contact_email != blank -%}
            <li><a href="mailto:{{ section.settings.contact_email }}">{{ section.settings.contact_email }}</a></li>
          {%- endif -%}
          <li><a href="mailto:privacy@velvetbotanica.com">privacy@velvetbotanica.com</a></li>
          {%- if section.settings.contact_phone != blank -%}
            <li><a href="tel:{{ section.settings.contact_phone }}">{{ section.settings.contact_phone }}</a></li>
          {%- endif -%}
          {%- if section.settings.contact_address != blank -%}
            <li class="footer-address">{{ section.settings.contact_address }}</li>
          {%- endif -%}
          <li><a href="/contact#contact-form">Contact Form</a></li>
        </ul>
      </div>

      <!-- About -->
      <div class="footer-col">
        <h4>{{ section.settings.col3_heading | default: 'About' }}</h4>
        <ul>
          {%- for link in linklists[section.settings.footer_about_menu].links -%}
            <li><a href="{{ link.url }}">{{ link.title }}</a></li>
          {%- endfor -%}
          {%- if shop.privacy_policy != blank -%}
            <li><a href="{{ shop.privacy_policy.url }}">Privacy Policy</a></li>
          {%- else -%}
            <li><a href="/policies/privacy-policy">Privacy Policy</a></li>
          {%- endif -%}
          {%- if shop.terms_of_service != blank -%}
            <li><a href="{{ shop.terms_of_service.url }}">Terms &amp; Conditions</a></li>
          {%- else -%}
            <li><a href="/policies/terms-of-service">Terms &amp; Conditions</a></li>
          {%- endif -%}
        </ul>
      </div>

    </div>

    <div class="footer-bottom">
      <span>&copy; {{ 'now' | date: '%Y' }} {{ shop.name }}. All rights reserved.</span>
      <span>{{ section.settings.footer_note }}</span>
    </div>
  </div>
</footer>

{% schema %}
{
  "name": "Footer",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo image"
    },
    {
      "type": "text",
      "id": "logo_text",
      "label": "Logo text (shown if no image)",
      "default": "Velvet Botanica"
    },
    {
      "type": "textarea",
      "id": "tagline",
      "label": "Brand tagline",
      "default": "Premium hair care crafted with nature's finest ingredients. Dermatologically tested and made in Italy."
    },
    {
      "type": "text",
      "id": "col1_heading",
      "label": "Column 1 heading",
      "default": "Shop"
    },
    {
      "type": "link_list",
      "id": "footer_shop_menu",
      "label": "Column 1 menu",
      "default": "footer"
    },
    {
      "type": "text",
      "id": "col2_heading",
      "label": "Column 2 heading",
      "default": "Contact"
    },
    {
      "type": "text",
      "id": "contact_email",
      "label": "Contact email",
      "default": "hello@phytorelax.com"
    },
    {
      "type": "text",
      "id": "contact_phone",
      "label": "Contact phone"
    },
    {
      "type": "textarea",
      "id": "contact_address",
      "label": "Address",
      "default": "A-Team Crescent, Paddy District New York, NY 10007 USA"
    },
    {
      "type": "text",
      "id": "col3_heading",
      "label": "Column 3 heading",
      "default": "About"
    },
    {
      "type": "link_list",
      "id": "footer_about_menu",
      "label": "Column 3 menu",
      "default": "footer"
    },
    {
      "type": "text",
      "id": "instagram_url",
      "label": "Instagram URL"
    },
    {
      "type": "text",
      "id": "facebook_url",
      "label": "Facebook URL"
    },
    {
      "type": "text",
      "id": "tiktok_url",
      "label": "TikTok URL"
    },
    {
      "type": "text",
      "id": "footer_note",
      "label": "Footer note",
      "default": "Made with love in Italy · Dermatologically tested"
    }
  ]
}
{% endschema %}
