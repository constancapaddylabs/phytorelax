<header class="site-header" role="banner">
  <div class="container">
    <div class="header-inner">

      <!-- Logo -->
      <a href="{{ routes.root_url }}" class="site-logo">
        {%- if section.settings.logo != blank -%}
          <img src="{{ section.settings.logo | image_url: width: 200 }}"
               alt="{{ shop.name }}"
               width="140"
               height="auto"
               loading="eager">
        {%- else -%}
          {{ shop.name }}
        {%- endif -%}
      </a>

      <!-- Desktop Nav -->
      <nav class="main-nav" aria-label="Main navigation">
        {%- for link in linklists[section.settings.menu].links -%}
          <a href="{{ link.url }}"
             {% if link.active %}class="active" aria-current="page"{% endif %}>
            {{ link.title }}
          </a>
        {%- endfor -%}
      </nav>

      <!-- Icons -->
      <div class="header-icons">
        <a href="{{ routes.search_url }}" class="header-icon-btn" aria-label="Search">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
          </svg>
        </a>

        <a href="{{ routes.account_url }}" class="header-icon-btn" aria-label="Account">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
            <circle cx="12" cy="7" r="4"/>
          </svg>
        </a>

        <a href="{{ routes.cart_url }}" class="header-icon-btn" aria-label="Cart ({{ cart.item_count }})">
          <svg width="20" height="20" fill="none" stroke="currentColor" stroke-width="1.8" viewBox="0 0 24 24">
            <path d="M6 2 3 6v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2V6l-3-4z"/>
            <line x1="3" y1="6" x2="21" y2="6"/>
            <path d="M16 10a4 4 0 0 1-8 0"/>
          </svg>
          {%- if cart.item_count > 0 -%}
            <span class="cart-count">{{ cart.item_count }}</span>
          {%- endif -%}
        </a>

        <!-- Mobile menu trigger -->
        <button class="mobile-menu-btn" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-nav">
          <span></span><span></span><span></span>
        </button>
      </div>

    </div>
  </div>
</header>

<!-- Mobile Nav Overlay -->
<nav id="mobile-nav" class="mobile-nav" aria-label="Mobile navigation">
  <div class="mobile-nav__header">
    <span class="site-logo">{{ shop.name }}</span>
    <button class="mobile-close-btn" aria-label="Close menu">&times;</button>
  </div>
  <div class="mobile-nav__links">
    {%- for link in linklists[section.settings.menu].links -%}
      <a href="{{ link.url }}">{{ link.title }}</a>
    {%- endfor -%}
  </div>
</nav>

{% schema %}
{
  "name": "Header",
  "settings": [
    {
      "type": "image_picker",
      "id": "logo",
      "label": "Logo"
    },
    {
      "type": "link_list",
      "id": "menu",
      "label": "Navigation menu",
      "default": "main-menu"
    }
  ]
}
{% endschema %}
