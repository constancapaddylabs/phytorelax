{%- assign featured = collections[section.settings.collection] -%}

{%- assign mockup_products = 'Curly Hair,Repair & Restore,Color Protect,Argan Luxury,Keratin Volume' | split: ',' -%}
{%- assign mockup_images = 'https://www.phytorelax.it/wp-content/uploads/2024/11/Curly-2.png,https://www.phytorelax.it/wp-content/uploads/2024/11/Repair-2.png,https://www.phytorelax.it/wp-content/uploads/2024/11/Color-2.png,https://www.phytorelax.it/wp-content/uploads/2024/11/Argan-2.png,https://www.phytorelax.it/wp-content/uploads/2025/06/Keratin-volume-box.jpg' | split: ',' -%}
{%- assign mockup_prices = '€ 18.90,€ 22.50,€ 19.90,€ 24.90,€ 21.00' | split: ',' -%}

<section class="section">
  <div class="container">

    <div class="section-header fade-up">
      {%- if section.settings.eyebrow != blank -%}
        <p class="eyebrow">{{ section.settings.eyebrow }}</p>
      {%- endif -%}
      <h2>{{ section.settings.heading | default: 'Bestsellers' }}</h2>
      <div class="divider divider--center"></div>
      {%- if section.settings.description != blank -%}
        <p>{{ section.settings.description }}</p>
      {%- endif -%}
    </div>

    <div class="collection-grid">
      {%- if featured != blank -%}
        {%- for product in featured.products limit: section.settings.product_limit -%}
          {% render 'product-card', product: product %}
        {%- endfor -%}
      {%- else -%}
        {%- for i in (0..3) -%}
          <div class="product-card">
            <div class="product-card__image-wrap">
              <a href="#">
                <img src="{{ mockup_images[i] }}"
                     alt="{{ mockup_products[i] }}"
                     loading="lazy"
                     style="background: var(--color-blush-light);">
              </a>
              {%- if i == 0 -%}<span class="product-card__badge">Bestseller</span>{%- endif -%}
              {%- if i == 2 -%}<span class="product-card__badge">New</span>{%- endif -%}
              <button class="product-card__quick-add btn" aria-label="Quick add">Quick Add</button>
            </div>
            <div class="product-card__body">
              <p class="product-card__vendor">PHYTORELAX</p>
              <p class="product-card__title">{{ mockup_products[i] }}</p>
              <p class="product-card__price">{{ mockup_prices[i] }}</p>
            </div>
          </div>
        {%- endfor -%}
      {%- endif -%}
    </div>

    {%- if section.settings.show_view_all -%}
      <div class="text-center mt-4">
        <a href="{{ featured.url | default: routes.collections_url }}" class="btn btn--outline">
          {{ section.settings.view_all_label | default: 'View All Products' }}
        </a>
      </div>
    {%- endif -%}

  </div>
</section>

{% schema %}
{
  "name": "Featured Collection",
  "settings": [
    { "type": "text",       "id": "eyebrow",       "label": "Eyebrow text",    "default": "Our Products" },
    { "type": "text",       "id": "heading",       "label": "Heading",         "default": "Bestsellers" },
    { "type": "textarea",  "id": "description",   "label": "Description" },
    { "type": "collection","id": "collection",    "label": "Collection" },
    { "type": "range",     "id": "product_limit", "label": "Products to show", "min": 2, "max": 12, "step": 1, "default": 4 },
    { "type": "checkbox",  "id": "show_view_all", "label": "Show 'View all' button", "default": true },
    { "type": "text",      "id": "view_all_label","label": "'View all' button text", "default": "View All Products" }
  ],
  "presets": [{ "name": "Featured Collection" }]
}
{% endschema %}
