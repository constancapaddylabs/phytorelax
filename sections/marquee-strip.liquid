<div class="marquee-strip" aria-hidden="true">
  <div class="marquee-track">
    {%- for i in (1..8) -%}
      <span class="marquee-item">{{ section.settings.text_1 | default: 'Free from mineral oils' }}</span>
      <span class="marquee-item">{{ section.settings.text_2 | default: 'Dermatologically tested' }}</span>
      <span class="marquee-item">{{ section.settings.text_3 | default: 'Made in Italy' }}</span>
      <span class="marquee-item">{{ section.settings.text_4 | default: 'No artificial colorants' }}</span>
    {%- endfor -%}
  </div>
</div>

{% schema %}
{
  "name": "Marquee Strip",
  "settings": [
    { "type": "text", "id": "text_1", "label": "Item 1", "default": "Free from mineral oils" },
    { "type": "text", "id": "text_2", "label": "Item 2", "default": "Dermatologically tested" },
    { "type": "text", "id": "text_3", "label": "Item 3", "default": "Made in Italy" },
    { "type": "text", "id": "text_4", "label": "Item 4", "default": "No artificial colorants" }
  ],
  "presets": [{ "name": "Marquee Strip" }]
}
{% endschema %}
